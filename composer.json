{
    "name": "maat/waffarha",
    "description": "Waffarha API client and integration package for Maat application.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Bendary",
            "email": "bendary@waffarha.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "Maat\\Waffarha\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Maat\\Waffarha\\WaffarhaServiceProvider"
            ],
            "aliases": {
                "Waffarha": "Maat\\Waffarha\\Facades\\Waffarha"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
